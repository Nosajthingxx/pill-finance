# pill.finance — environment variables
#
# Copy this file to .env.local for local development.
# In production, set these in the Vercel project dashboard → Settings → Environment Variables.
# After setting in Vercel, run `vercel env pull .env.local` to sync to your local machine.

# ─── Database (Vercel Postgres) ──────────────────────────────────────────
# Auto-populated by Vercel when you create a Vercel Postgres database and
# link it to this project. All four are set by Vercel Postgres; we only
# use POSTGRES_URL directly.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Auth.js v5 ──────────────────────────────────────────────────────────
# Random 32-byte secret used to sign session cookies.
# Generate with: `openssl rand -base64 32` or `npx auth secret`
AUTH_SECRET=

# Base URL for callbacks. In production, Vercel sets this automatically.
# For local dev, use http://localhost:3000
AUTH_URL=http://localhost:3000

# Trust the X-Forwarded-Host header when behind Vercel's proxy.
AUTH_TRUST_HOST=true

# ─── Resend (magic link email) ───────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
# Free tier: 100 emails/day, 3000/month.
AUTH_RESEND_KEY=

# The "from" address for magic link emails. Must be a verified domain in Resend.
# Suggested: login@pill.finance once the domain is verified.
AUTH_EMAIL_FROM=login@pill.finance
